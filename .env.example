GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# ── Frontend → PHP API base URL (src/App.tsx) ───────────────────────────────────
# Production (Hostinger, same-origin api/ folder): leave this UNSET.
# The app already falls back to a same-origin relative "/api", which resolves
# correctly wherever it's deployed — do not set this when building for production.
#
# Only set this for local XAMPP testing, where the PHP API lives at a different
# path than the Vite dev server (no trailing slash, no /send-mail.php):
# VITE_API_URL=http://localhost/sofia-clinic/api

# ── PHP Mailer (api/send-mail.php) ──────────────────────────────────────────────
# Gmail example: enable "App Passwords" in your Google account for SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=noreply@soufia-clinic.com
SMTP_FROM_NAME="Soufia Clinic"
ADMIN_EMAIL=bentaouiloussama@gmail.com
